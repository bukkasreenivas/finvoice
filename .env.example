# ─── LLM ────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here
GROQ_API_KEY=your_key_here          # fallback LLM via Groq (Llama 3)

# ─── Banking — Account Aggregator via Finvu sandbox ─────────────────────────
FINVU_CLIENT_ID=your_finvu_client_id
FINVU_CLIENT_SECRET=your_finvu_client_secret
AA_ENV=sandbox                      # set to "production" when going live

# ─── Database ────────────────────────────────────────────────────────────────
# Local dev: set by docker-compose automatically
# Production (Supabase): replace with your Supabase connection string
# Note: Supabase free tier pauses after 1 week of inactivity — resume via dashboard
DATABASE_URL=postgresql://user:password@localhost:5432/finvoice

# Supabase-specific vars (required in production)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Cache — Redis ───────────────────────────────────────────────────────────
# Local dev: set by docker-compose automatically
# Production (Upstash): replace with your Upstash Redis URL
# Upstash free tier: 10,000 commands/day — sufficient for demo workloads
REDIS_URL=redis://localhost:6379

# Upstash-specific var (required in production)
UPSTASH_REDIS_URL=rediss://your-upstash-url:6379

# ─── Voice transcription ─────────────────────────────────────────────────────
# Local dev: defaults to self-hosted faster-whisper (no key needed)
# Production: Deepgram free tier gives 45 minutes/month
DEEPGRAM_API_KEY=your_deepgram_key

# ─── Deployment ──────────────────────────────────────────────────────────────
# Frontend (Vercel) needs to know the Railway backend URL for WebSocket connections
RAILWAY_BACKEND_URL=https://your-railway-app.up.railway.app

# ─── App ─────────────────────────────────────────────────────────────────────
SECRET_KEY=your_jwt_secret
ENVIRONMENT=development             # set to "production" on Railway
